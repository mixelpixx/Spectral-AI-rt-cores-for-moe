<?xml version="1.0" encoding="utf-8"?>
<!--
  cuda_msvc_fix.props

  Workaround for CUDA 13.2 MSBuild targets injecting a malformed
  -Xcompiler="/EHsc -Ob2" flag (space inside quotes) that causes nvcc to
  treat the two MSVC flags as separate arguments / input files.

  By clearing AdditionalCompilerOptions we prevent the injection.
  The CUDA runtime library links EHsc support independently.
-->
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemDefinitionGroup>
    <CudaCompile>
      <AdditionalCompilerOptions></AdditionalCompilerOptions>
    </CudaCompile>
  </ItemDefinitionGroup>
</Project>
